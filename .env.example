# ── OSC source (Pocket Scion device) ─────────────────────────────────────────
# Host to bind for incoming UDP/OSC messages. 0.0.0.0 accepts from any interface.
OSC_HOST=0.0.0.0
OSC_PORT=11046

# ── HTTP / WebSocket server ───────────────────────────────────────────────────
HTTP_PORT=3000

# ── InfluxDB v2 (optional — only needed for session recording) ────────────────
INFLUX_URL=http://127.0.0.1:8086
INFLUX_TOKEN=your-influxdb-token-here
INFLUX_ORG=your-org-name
INFLUX_BUCKET=scion
INFLUX_MEASUREMENT=scion_stats

# ── Cloud relay (optional — only needed for live internet publishing) ─────────
# Set RELAY_URL to your deployed relay.js instance (must be wss://)
# PUB_SECRET must match the PUB_SECRET env var set on the relay server.
RELAY_URL=wss://your-relay.up.railway.app/ws
PUB_SECRET="your-shared-secret-here"
